# -----------------------------------------------------------------------------
# Lutheran LLM - Environment Configuration Template
# Copy this file to '.env' and fill in the values for local run.
# -----------------------------------------------------------------------------

# Database Connection
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/lutheran_db

# Chroma Vector Database Path
CHROMA_DB_PATH=./.chroma

# Primary translation version for searches (WEB, KJV, MKJV)
PRIMARY_SEARCH_VERSION=WEB

# RAG Configuration
# Number of confessional documents (Book of Concord chunks) to retrieve
RAG_CONFESSIONAL_K=5
# Maximum size of biblical retrieval pool to search over before thresholding
RAG_BIBLICAL_MAX_POOL=50
# Maximum L2 distance threshold for Scripture relevance (lower is stricter)
RAG_BIBLICAL_DISTANCE_THRESHOLD=1.0

# LLM Provider ('ollama' or 'groq')
LLM_PROVIDER=ollama

# Ollama settings (used if LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_PREDICT=512
OLLAMA_TEMPERATURE=0.0
OLLAMA_NUM_CTX=2048

# Groq settings (used if LLM_PROVIDER=groq)
GROQ_API_KEY=your-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.0
GROQ_MAX_TOKENS=512
